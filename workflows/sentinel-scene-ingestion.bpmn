  <bpmn:collaboration id="Collaboration_11emlyv">
    <bpmn:participant id="Pool_1" name="Sentinel Scene Ingestion" processRef="sentinel-scene-ingestion" />
  </bpmn:collaboration>
  <bpmn:process id="sentinel-scene-ingestion" name="Sentinel Scene Ingestion" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:startEvent id="StartEvent_1" name="Start scene ingestion">
      <bpmn:outgoing>Flow_0bhhyxl</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0bhhyxl" sourceRef="StartEvent_1" targetRef="sentinel_download_scene" />
    <bpmn:serviceTask id="sentinel_download_scene" name="Download Scene" camunda:asyncAfter="true" camunda:type="external" camunda:topic="sentinel_download_scene">
      <bpmn:incoming>Flow_0bhhyxl</bpmn:incoming>
      <bpmn:outgoing>Flow_1732rdv</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1732rdv" sourceRef="sentinel_download_scene" targetRef="sentinel_unzip" />
    <bpmn:serviceTask id="sentinel_unzip" name="Unzip" camunda:asyncAfter="true" camunda:type="external" camunda:topic="sentinel_unzip">
      <bpmn:incoming>Flow_1732rdv</bpmn:incoming>
      <bpmn:outgoing>Flow_07az1q0</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_07az1q0" sourceRef="sentinel_unzip" targetRef="sentinel_check_integrity" />
    <bpmn:serviceTask id="sentinel_check_integrity" name="Check Integrity" camunda:asyncAfter="true" camunda:type="external" camunda:topic="sentinel_check_integrity">
      <bpmn:incoming>Flow_07az1q0</bpmn:incoming>
      <bpmn:outgoing>Flow_07ye5k2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_1i2o6lt">
      <bpmn:incoming>Flow_07ye5k2</bpmn:incoming>
      <bpmn:outgoing>Flow_1a2vk5a</bpmn:outgoing>
      <bpmn:outgoing>Flow_1f8o5vr</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_07ye5k2" sourceRef="sentinel_check_integrity" targetRef="Gateway_1i2o6lt" />
    <bpmn:sequenceFlow id="Flow_1a2vk5a" sourceRef="Gateway_1i2o6lt" targetRef="sentinel_extract_metadata">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{S(scene).prop("collection").stringValue() != ""}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="sentinel_extract_metadata" name="Extract Metadata" camunda:asyncAfter="true" camunda:type="external" camunda:topic="sentinel_extract_metadata">
      <bpmn:incoming>Flow_1a2vk5a</bpmn:incoming>
      <bpmn:outgoing>Flow_0d6m1mi</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0d6m1mi" sourceRef="sentinel_extract_metadata" targetRef="sentinel_register_metadata" />
    <bpmn:serviceTask id="sentinel_register_metadata" name="Register Metadata" camunda:asyncAfter="true" camunda:type="external" camunda:topic="sentinel_register_metadata">
      <bpmn:incoming>Flow_0d6m1mi</bpmn:incoming>
      <bpmn:outgoing>Flow_0es6yjm</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_1j51gik">
      <bpmn:incoming>Flow_0es6yjm</bpmn:incoming>
      <bpmn:incoming>Flow_1f8o5vr</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0es6yjm" sourceRef="sentinel_register_metadata" targetRef="Event_1j51gik" />
    <bpmn:sequenceFlow id="Flow_1f8o5vr" name="if no collection given, skip metadata part" sourceRef="Gateway_1i2o6lt" targetRef="Event_1j51gik">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{S(scene).prop("collection").stringValue() == ""}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
