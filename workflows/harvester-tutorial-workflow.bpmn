      <bpmn:incoming>Flow_1in26fb</bpmn:incoming>
      <bpmn:outgoing>Flow_0rj5gas</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics camunda:asyncAfter="true" camunda:collection="${items.elements()}" camunda:elementVariable="item" />
