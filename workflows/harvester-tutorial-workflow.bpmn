  <bpmn:process id="harvester-tutorial-workflow" name="Harvester Tutorial Workflow" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_0vhy3j0</bpmn:outgoing>
    </bpmn:startEvent>
