      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ExternalWorkerTask_1" bpmnElement="landsat_download_scene">
        <dc:Bounds x="403" y="138" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ExternalWorkerTask_2" bpmnElement="landsat_unpack">
