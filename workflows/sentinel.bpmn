  <bpmn:message id="Message_3u04e9s" name="sentinel-start-order" />
  <bpmn:collaboration id="Collaboration_062u33n">
    <bpmn:participant id="Pool_1" name="Sentinel Data Ingestion" processRef="sentinel-data-ingestion" />
  </bpmn:collaboration>
  <bpmn:process id="sentinel-data-ingestion" name="Sentinel Data Ingestion" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:startEvent id="sentinel_timer_start_event" name="Start every hour">
      <bpmn:outgoing>Flow_0ek6gn8</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1mse4fw">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">0 0 * * * ?</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:startEvent id="sentinel_start_event" name="Start manually">
      <bpmn:outgoing>Flow_1iv0i8v</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0at8s0z" messageRef="Message_3u04e9s" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="sentinel_continuous_discovery" name="Continuous Discovery" camunda:asyncAfter="true" camunda:type="external" camunda:topic="sentinel_continuous_discovery">
      <bpmn:incoming>Flow_0ek6gn8</bpmn:incoming>
      <bpmn:outgoing>Flow_1xx1ah2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0ek6gn8" sourceRef="sentinel_timer_start_event" targetRef="sentinel_continuous_discovery" />
    <bpmn:sequenceFlow id="Flow_1iv0i8v" sourceRef="sentinel_start_event" targetRef="sentinel_ondemand_discovery" />
    <bpmn:serviceTask id="sentinel_ondemand_discovery" name="On-demand Discovery" camunda:asyncAfter="true" camunda:type="external" camunda:topic="sentinel_ondemand_discovery">
      <bpmn:incoming>Flow_1iv0i8v</bpmn:incoming>
      <bpmn:outgoing>Flow_0pdlcz5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0pdlcz5" sourceRef="sentinel_ondemand_discovery" targetRef="Gateway_11p37gr" />
    <bpmn:sequenceFlow id="Flow_1xx1ah2" sourceRef="sentinel_continuous_discovery" targetRef="Gateway_11p37gr" />
    <bpmn:sequenceFlow id="Flow_1k4n5o7" name="scenes found" sourceRef="Gateway_11p37gr" targetRef="sentinel_scene_ingestion">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{!S(scenes).elements().isEmpty()}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0kbc8tw" sourceRef="sentinel_scene_ingestion" targetRef="Event_1guz2an" />
    <bpmn:sequenceFlow id="Flow_0cmgyn1" name="no scenes found" sourceRef="Gateway_11p37gr" targetRef="Event_1guz2an">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{S(scenes).elements().isEmpty()}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_1guz2an">
      <bpmn:incoming>Flow_0kbc8tw</bpmn:incoming>
      <bpmn:incoming>Flow_0cmgyn1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:callActivity id="sentinel_scene_ingestion" name="Sentinel Scene Ingestion" calledElement="sentinel-scene-ingestion">
      <bpmn:extensionElements>
        <camunda:in source="scene" target="scene" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1k4n5o7</bpmn:incoming>
      <bpmn:outgoing>Flow_0kbc8tw</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics camunda:asyncAfter="true" camunda:collection="${scenes}" camunda:elementVariable="scene" />
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="Gateway_11p37gr">
      <bpmn:incoming>Flow_0pdlcz5</bpmn:incoming>
      <bpmn:incoming>Flow_1xx1ah2</bpmn:incoming>
      <bpmn:outgoing>Flow_1k4n5o7</bpmn:outgoing>
      <bpmn:outgoing>Flow_0cmgyn1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
  </bpmn:process>
